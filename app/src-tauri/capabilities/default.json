{
  "identifier": "default",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": ["http://localhost:1420/*", "http://localhost:14200/*"]
  },
  "permissions": [
    "core:default",
    "shell:allow-open",
    "store:default",
    "dialog:default",
    "fs:default",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:allow-appdata-meta-recursive",
    "updater:default",
    "allow-cmd-auth-request-code",
    "allow-cmd-auth-sign-in",
    "allow-cmd-auth-check-password",
    "allow-cmd-get-files",
    "allow-cmd-upload-file",
    "allow-cmd-connect",
    "allow-cmd-log",
    "allow-cmd-delete-file",
    "allow-cmd-download-file",
    "allow-cmd-move-files",
    "allow-cmd-create-folder",
    "allow-cmd-delete-folder",
    "allow-cmd-get-bandwidth",
    "allow-cmd-get-preview",
    "allow-cmd-logout",
    "allow-cmd-scan-folders",
    "allow-cmd-search-global",
    "allow-cmd-check-connection",
    "allow-cmd-rename-folder",
    "allow-cmd-start-auto-sync",
    "allow-cmd-is-network-available",
    "allow-cmd-clean-cache",
    "allow-cmd-get-thumbnail",
    "allow-cmd-get-stream-info",
    "allow-cmd-cancel-transfer",
    "allow-cmd-auth-qr-login",
    "allow-cmd-auth-qr-poll",
    "allow-cmd-get-api-settings",
    "allow-cmd-update-api-settings",
    "allow-cmd-regenerate-api-key",
    "allow-cmd-generate-sprite-sheet",
    "allow-cmd-get-cache-status",
    "allow-cmd-delete-cache",
    "allow-cmd-start-background-cache",
    "allow-cmd-stop-background-cache"
  ]
}